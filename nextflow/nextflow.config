/*
 * Nextflow Configuration File for NJU-seq Pipeline
 *
 * This configuration defines the execution environment, resource limits,
 * and process-specific settings for the Nm-site identification workflow.
 */

// Global parameters
params {
    // Project paths
    project_root = "../"
    njuseq_dir = "${project_root}/NJU_seq"
    data_dir = "${project_root}/NJU_seq_reads"
    output_dir = "${project_root}/NJU_seq_output"
    index_dir = "${project_root}/index"

    // Sample configuration
    samples = [
        'NJU6220', 'NJU6221', 'NJU6222', 'NJU6223',
        'NJU6224', 'NJU6225', 'NJU6226', 'NJU6227',
        'NJU6228', 'NJU6229', 'NJU6230', 'NJU6231',
        'NJU6232', 'NJU6233', 'NJU6234', 'NJU6235'
    ]

    tissues = ['leaf', 'root', 'stem', 'flower']
    rna_types = ['25s', '18s', '5-8s']

    // Reference files
    bac_index = "${index_dir}/bac_rna"
    rrna_index = "${index_dir}/ath/ath_rrna_total"
    mrna_index = "${index_dir}/ath/ath_protein_coding"
    exon_info = "${index_dir}/ath/exon.info"

    // Performance parameters
    threads = System.getenv('NJU_THREADS') ? System.getenv('NJU_THREADS').toInteger() : 24
    bowtie_threads = System.getenv('NJU_BOWTIE_THREADS') ? System.getenv('NJU_BOWTIE_THREADS').toInteger() : 22
    parallel_jobs = System.getenv('NJU_PARALLEL_JOBS') ? System.getenv('NJU_PARALLEL_JOBS').toInteger() : 20

    // Quality thresholds
    min_score = 0.5
    min_coverage = 5
    max_multimatches = 15

    // Output settings
    save_intermediate = false
    publish_mode = 'copy'  // 'copy', 'move', 'link', or 'symlink'

    // Help flags
    help = false
}

// Container configuration
docker {
    enabled = false
    container = 'ivanwoo/nju-seq:latest'
    pullTimeout = '20 min'
    fixOwnership = true
}

singularity {
    enabled = false
    containerPath = '/usr/local/singularity/nju-seq.sif'
    autoMounts = true
}

// AWS configuration (for cloud execution)
aws {
    region = 'us-east-1'
    batch.cli_path = '/usr/local/bin/aws'
}

// HPC configuration (LSF/BSUB)
lsf {
    enabled = false
    queue = 'normal'
    jobName = 'nju-seq'
    extra = "-R \"rusage[mem=4000]\""
}

// SLURM configuration
slurm {
    enabled = false
    queue = 'normal'
    account = ''
    extra = "--mem=4000"
}

// Process resource labels
process {
    withLabel: 'bacterial_align' {
        cpus = { params.bowtie_threads }
        memory = { 8.GB * task.attempt }
        time = { 4.h * task.attempt }
        penv = 'omp'
        clusterOptions = "-n ${params.bowtie_threads} -J bac_align"
    }

    withLabel: 'rrna_align' {
        cpus = { params.bowtie_threads }
        memory = { 8.GB * task.attempt }
        time = { 4.h * task.attempt }
        penv = 'omp'
        clusterOptions = "-n ${params.bowtie_threads} -J rrna_align"
    }

    withLabel: 'mrna_align' {
        cpus = { params.bowtie_threads }
        memory = { 12.GB * task.attempt }
        time = { 6.h * task.attempt }
        penv = 'omp'
        clusterOptions = "-n ${params.bowtie_threads} -J mrna_align"
    }

    withLabel: 'filter' {
        cpus = { params.parallel_jobs }
        memory = { 4.GB * task.attempt }
        time = { 2.h * task.attempt }
        penv = 'smp'
    }

    withLabel: 'scoring' {
        cpus = 4
        memory = { 8.GB * task.attempt }
        time = { 2.h * task.attempt }
        penv = 'smp'
    }

    withLabel: 'visualization' {
        cpus = 2
        memory = { 4.GB * task.attempt }
        time = { 1.h * task.attempt }
        penv = 'smp'
    }

    withLabel: 'report' {
        cpus = 1
        memory = { 2.GB * task.attempt }
        time = { 30.m * task.attempt }
    }

    errorStrategy = { task.exitStatus in [104, 134, 137, 139, 140, 143, 247] ? 'retry' : 'finish' }
    maxRetries = 3
    maxErrors = '-1'

    // Exclude execution from scratch to prevent I/O issues
    scratch = false

    // Cleanup intermediate files
    cleanup = true
}

// Log configuration
log.info """\
================================================================================
NJU-seq Pipeline - Nextflow Configuration
================================================================================
Project Root    : ${params.project_root}
Data Directory  : ${params.data_dir}
Output Directory: ${params.output_dir}
Index Directory  : ${params.index_dir}
Samples         : ${params.samples.size()} samples
Tissues         : ${params.tissues.join(', ')}
rRNA Types      : ${params.rna_types.join(', ')}
Threads         : ${params.threads}
Parallel Jobs   : ${params.parallel_jobs}
================================================================================
"""
.stripIndent()

// Validation
if (!file(params.njuseq_dir).exists()) {
    exit 1, "NJU_seq directory not found: ${params.njuseq_dir}"
}
if (!file(params.data_dir).exists()) {
    exit 1, "Data directory not found: ${params.data_dir}"
}
if (!file(params.index_dir).exists()) {
    exit 1, "Index directory not found: ${params.index_dir}"
}
